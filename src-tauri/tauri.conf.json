{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorePilot",
  "version": "0.1.9",
  "identifier": "com.corepilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CorePilot",
        "width": 1280,
        "height": 832,
        "minWidth": 1060,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true,
        "theme": "Dark",
        "additionalBrowserArgs": "--disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows --disable-features=CalculateNativeWinOcclusion,IntensiveWakeUpThrottling"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/sensord"],
    "resources": {
      "target/release/corepilot_overlay.dll": "corepilot_overlay.dll"
    },
    "windows": {
      "webviewInstallMode": { "type": "skip" }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
