{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorePilot",
  "version": "0.1.0",
  "identifier": "com.corepilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CorePilot",
        "width": 1280,
        "height": 832,
        "minWidth": 1060,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/sensord"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
